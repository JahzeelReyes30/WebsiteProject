# Copy this file to .env.local and fill in real values from your Supabase
# project's Settings -> API page. .env.local is gitignored, so real values
# never get committed. See README.md for the full setup walkthrough.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: email alert on new bookings. Without these two set, bookings
# still save fine, they just won't email anyone. Get an API key from
# https://resend.com (free tier) after verifying your account.
RESEND_API_KEY=your-resend-api-key
BOOKING_NOTIFY_EMAIL=you@example.com

# Canonical site URL, used for the sitemap, robots.txt, and SEO metadata.
NEXT_PUBLIC_SITE_URL=https://your-domain-or-vercel-url.example
